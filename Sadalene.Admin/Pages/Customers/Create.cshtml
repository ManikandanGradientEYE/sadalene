@page
@model Sadalene.Admin.Pages.Customers.CreateModel
@{
    ViewData["Title"] = "Add Customer";
    ViewData["ActiveMenu"] = "Customers";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Add Customer</h5>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Input.FullName" class="form-label fw-semibold">Full Name</label>
                    <input asp-for="Input.FullName" class="form-control" />
                    <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Phone" class="form-label fw-semibold">Phone</label>
                    <input asp-for="Input.Phone" class="form-control" />
                    <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Input.Email" type="email" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Input.Address" class="form-label fw-semibold">Address</label>
                    <textarea asp-for="Input.Address" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.City" class="form-label fw-semibold">City</label>
                    <input asp-for="Input.City" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.State" class="form-label fw-semibold">State</label>
                    <input asp-for="Input.State" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.GstNumber" class="form-label fw-semibold">GST Number</label>
                    <input asp-for="Input.GstNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.AgentId" class="form-label fw-semibold">Agent</label>
                    <select asp-for="Input.AgentId" class="form-select" asp-items="Model.Agents">
                        <option value="0">— None (Walk-in) —</option>
                    </select>
                    <div class="form-text">Link this customer to the agent who referred them, if any.</div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary mt-3"><i class="bi bi-check-lg me-2"></i>Create Customer</button>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
