@page
@model Sadalene.Admin.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customers";
    ViewData["ActiveMenu"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>Customers</h5>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add Customer</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Phone</th><th>City</th><th>GST</th><th>Orders</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Customers)
                {
                    <tr>
                        <td class="fw-semibold">@c.FullName</td>
                        <td>@c.Phone</td>
                        <td class="text-muted">@c.City</td>
                        <td class="text-muted small">@c.GstNumber</td>
                        <td><span class="badge bg-primary">@c.Orders.Count</span></td>
                        <td><span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <a asp-page="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a asp-page="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary ms-1"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
