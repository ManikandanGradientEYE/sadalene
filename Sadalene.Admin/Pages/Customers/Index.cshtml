@page
@model Sadalene.Admin.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customers";
    ViewData["ActiveMenu"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-people me-2"></i>Customers</h5>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add Customer</a>
</div>

<div class="mb-3" data-live-search data-target="#customers-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by name, code, phone, email or city..." value="@Model.Search" />
</div>
<div id="customers-table-region">
    <partial name="_CustomersTable" model="Model" />
</div>
