@model Sadalene.Admin.Pages.Customers.IndexModel

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Phone</th><th>City</th><th>GST</th><th>Agent</th><th>Orders</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Customers.Items)
                {
                    <tr>
                        <td class="fw-semibold">@c.FullName</td>
                        <td>@c.Phone</td>
                        <td class="text-muted">@c.City</td>
                        <td class="text-muted small">@c.GstNumber</td>
                        <td>
                            @if (c.Agent != null)
                            {
                                <span class="badge bg-info-subtle text-info-emphasis">@c.Agent.FullName</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td><span class="badge bg-primary">@c.Orders.Count</span></td>
                        <td><span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <a asp-page="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                            <a asp-page="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary ms-1"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                }
                @if (Model.Customers.Items.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No customers found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.Customers" />
</div>
