@page "{id:int}"
@model Sadalene.Admin.Pages.Customers.DetailsModel
@{
    ViewData["Title"] = "Customer Details";
    ViewData["ActiveMenu"] = "Customers";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">@Model.Customer!.FullName</h5>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Customer Info</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Phone</dt>     <dd class="col-7">@Model.Customer.Phone</dd>
                    <dt class="col-5 text-muted">Email</dt>     <dd class="col-7">@(Model.Customer.Email ?? "—")</dd>
                    <dt class="col-5 text-muted">City</dt>      <dd class="col-7">@(Model.Customer.City ?? "—")</dd>
                    <dt class="col-5 text-muted">State</dt>     <dd class="col-7">@(Model.Customer.State ?? "—")</dd>
                    <dt class="col-5 text-muted">GST</dt>       <dd class="col-7">@(Model.Customer.GstNumber ?? "—")</dd>
                    <dt class="col-5 text-muted">Joined</dt>    <dd class="col-7">@Model.Customer.CreatedAt.ToString("dd MMM yyyy")</dd>
                    <dt class="col-5 text-muted">Last Login</dt><dd class="col-7">@(Model.Customer.LastLoginAt?.ToString("dd MMM yyyy") ?? "Never")</dd>
                </dl>
                <a asp-page="Edit" asp-route-id="@Model.Customer.Id" class="btn btn-sm btn-outline-primary mt-3 w-100">Edit</a>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header">Order History</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Order #</th><th>Date</th><th>Items</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.Customer.Orders.OrderByDescending(x => x.OrderDate))
                        {
                            <tr>
                                <td><a asp-page="/Orders/Details" asp-route-id="@o.Id">@o.OrderNumber</a></td>
                                <td class="text-muted small">@o.OrderDate.ToString("dd MMM yyyy")</td>
                                <td>@o.Items.Count</td>
                                <td><span class="badge @(o.Status == Sadalene.Core.Enums.OrderStatus.Pending ? "bg-warning text-dark" : o.Status == Sadalene.Core.Enums.OrderStatus.Cancelled ? "bg-danger" : "bg-success")">@o.Status</span></td>
                            </tr>
                        }
                        @if (!Model.Customer.Orders.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">No orders</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
