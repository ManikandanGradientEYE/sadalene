@page
@model Sadalene.Admin.Pages.Orders.CreateModel
@{
    ViewData["Title"] = "Add Order";
    ViewData["ActiveMenu"] = "Orders";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Add Order</h5>
</div>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

    <!-- Order For -->
    <div class="card mb-3">
        <div class="card-header fw-semibold py-2 bg-light"><i class="bi bi-person me-2"></i>Order For</div>
        <div class="card-body">
            <div class="btn-group mb-3" role="group">
                <input type="radio" class="btn-check" name="orderSourceToggle" id="sourceWalkin" checked>
                <label class="btn btn-outline-primary btn-sm" for="sourceWalkin">Walk-in Customer</label>
                <input type="radio" class="btn-check" name="orderSourceToggle" id="sourceAgent">
                <label class="btn btn-outline-primary btn-sm" for="sourceAgent">Agent's Customer</label>
            </div>

            <div id="walkinSection">
                <label class="form-label fw-semibold">Customer <span class="text-danger">*</span></label>
                <select id="walkinCustomerSelect" name="Input.CustomerId" class="form-select">
                    <option value="">— Select Customer —</option>
                    @foreach (var c in Model.WalkinCustomers)
                    {
                        <option value="@c.Id">@c.FullName (@c.Phone)</option>
                    }
                </select>
            </div>

            <div id="agentSection" class="d-none">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Agent <span class="text-danger">*</span></label>
                        <select id="agentSelect" name="Input.AgentId" class="form-select" disabled>
                            <option value="">— Select Agent —</option>
                            @foreach (var a in Model.Agents)
                            {
                                <option value="@a.Id">@a.FullName (@a.Phone)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Customer <span class="text-danger">*</span></label>
                        <select id="agentCustomerSelect" name="Input.CustomerId" class="form-select" disabled>
                            <option value="">— Select Agent first —</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Items -->
    <div class="card mb-3">
        <div class="card-header fw-semibold py-2 bg-light"><i class="bi bi-basket me-2"></i>Order Items</div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-semibold">Scan Barcode / QR Code</label>
                <div class="input-group" style="max-width:420px">
                    <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                    <input type="text" id="scanInput" class="form-control" placeholder="Scan or type SKU, then press Enter" autocomplete="off" />
                </div>
                <div id="scanFeedback" class="small mt-1"></div>
                <div class="form-text">Works with a USB/Bluetooth barcode or QR scanner (types like a keyboard), or type the SKU by hand and press Enter. Only adds a product if it's found in stock.</div>
            </div>

            <table class="table table-sm align-middle mb-2">
                <thead>
                    <tr><th>Product</th><th style="width:100px">Quantity</th><th style="width:150px">Type</th><th style="width:90px">UOM</th><th style="width:140px">Stock</th><th style="width:40px"></th></tr>
                </thead>
                <tbody id="itemsBody"></tbody>
            </table>
            <button type="button" id="addItemBtn" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-plus-lg me-1"></i>Add Item
            </button>
        </div>
    </div>

    <!-- Notes -->
    <div class="card mb-3">
        <div class="card-header fw-semibold py-2 bg-light"><i class="bi bi-card-text me-2"></i>Notes</div>
        <div class="card-body">
            <textarea name="Input.Notes" class="form-control" rows="2" placeholder="Optional notes for this order"></textarea>
        </div>
    </div>

    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-2"></i>Create Order</button>
    <a asp-page="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>

<!-- Row template for a single order line item; cloned by JS so newly added rows start from pristine markup -->
<template id="itemRowTemplate">
    <tr class="item-row">
        <td>
            <select class="form-select form-select-sm product-select" required>
                <option value="">— Select Product —</option>
                @foreach (var p in Model.Products)
                {
                    <option value="@p.Id">@p.Name (@(p.ProductCode ?? "—"))</option>
                }
            </select>
        </td>
        <td><input type="number" class="form-control form-control-sm qty-input" step="0.001" min="0.001" required /></td>
        <td class="unit-type-cell d-none">
            <div class="btn-group btn-group-sm w-100" role="group">
                <input type="radio" class="btn-check unit-full-radio" autocomplete="off" checked>
                <label class="btn btn-outline-secondary">Full</label>
                <input type="radio" class="btn-check unit-half-radio" autocomplete="off">
                <label class="btn btn-outline-secondary">Half</label>
            </div>
            <div class="text-muted small eff-qty-cell"></div>
        </td>
        <td class="text-muted small uom-cell">—</td>
        <td class="text-muted small stock-cell"></td>
        <td><button type="button" class="btn btn-sm btn-outline-danger remove-item-btn"><i class="bi bi-trash"></i></button></td>
    </tr>
</template>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // --- Order For: walk-in vs agent toggle ---
        const sourceWalkin = document.getElementById('sourceWalkin');
        const sourceAgent = document.getElementById('sourceAgent');
        const walkinSection = document.getElementById('walkinSection');
        const agentSection = document.getElementById('agentSection');
        const walkinCustomerSelect = document.getElementById('walkinCustomerSelect');
        const agentSelect = document.getElementById('agentSelect');
        const agentCustomerSelect = document.getElementById('agentCustomerSelect');

        function updateOrderSourceUI() {
            const isAgent = sourceAgent.checked;
            walkinSection.classList.toggle('d-none', isAgent);
            agentSection.classList.toggle('d-none', !isAgent);

            if (isAgent) {
                walkinCustomerSelect.tomselect.disable();
                agentSelect.tomselect.enable();
                agentCustomerSelect.tomselect.enable();
            } else {
                walkinCustomerSelect.tomselect.enable();
                agentSelect.tomselect.disable();
                agentCustomerSelect.tomselect.disable();
            }
        }
        sourceWalkin.addEventListener('change', updateOrderSourceUI);
        sourceAgent.addEventListener('change', updateOrderSourceUI);
        updateOrderSourceUI();

        agentSelect.tomselect.on('change', async function (agentId) {
            agentCustomerSelect.tomselect.clear(true);
            agentCustomerSelect.tomselect.clearOptions();
            agentCustomerSelect.tomselect.addOption({ value: '', text: agentId ? 'Loading...' : '— Select Agent first —' });
            agentCustomerSelect.tomselect.refreshOptions(false);

            if (!agentId) return;

            const data = await fetch(`/api/master/agent-customers?agentId=${agentId}`).then(r => r.json());
            agentCustomerSelect.tomselect.clearOptions();
            agentCustomerSelect.tomselect.addOption({ value: '', text: data.length ? '— Select Customer —' : 'No customers for this agent' });
            data.forEach(c => agentCustomerSelect.tomselect.addOption({ value: String(c.id), text: `${c.fullName} (${c.phone})` }));
            agentCustomerSelect.tomselect.refreshOptions(false);
        });

        // --- Order Items: repeatable rows ---
        let itemIndex = 0;
        const itemsBody = document.getElementById('itemsBody');
        const template = document.getElementById('itemRowTemplate');

        // Tracks which row currently holds a given productId, so scanning the same SKU twice
        // increments that row's quantity instead of adding a duplicate row.
        const rowsByProductId = new Map();

        function currentMultiplier(rowRefs) {
            return !rowRefs.unitTypeCell.classList.contains('d-none') && rowRefs.halfRadio.checked ? 0.5 : 1;
        }

        function updateRowMaxAndHint(rowRefs) {
            const { qtyInput, effQtyCell, uomHidden } = rowRefs;
            const stock = parseFloat(rowRefs.tr.dataset.stock || '0');
            const mult = currentMultiplier(rowRefs);

            qtyInput.max = mult > 0 ? stock / mult : stock;

            if (rowRefs.unitTypeCell.classList.contains('d-none')) {
                effQtyCell.textContent = '';
                return;
            }
            const qty = parseFloat(qtyInput.value) || 0;
            effQtyCell.textContent = `= ${(qty * mult).toFixed(2)} ${uomHidden.value}`;
        }

        async function applyProductInfo(rowRefs, productId) {
            const { tr, uomCell, stockCell, uomHidden, qtyInput, unitTypeCell, fullRadio, halfRadio, unitTypeHidden } = rowRefs;

            for (const [pid, row] of rowsByProductId) if (row === tr) rowsByProductId.delete(pid);

            if (!productId) {
                uomCell.textContent = '—';
                stockCell.textContent = '';
                uomHidden.value = '';
                qtyInput.removeAttribute('max');
                unitTypeCell.classList.add('d-none');
                fullRadio.checked = true;
                unitTypeHidden.value = 'Full';
                rowRefs.effQtyCell.textContent = '';
                return null;
            }

            const info = await fetch(`/api/master/product-info?productId=${productId}`).then(r => r.json());
            uomCell.textContent = info.uom;
            stockCell.textContent = `Stock: ${info.stock}`;
            uomHidden.value = info.uom;
            tr.dataset.stock = info.stock;

            unitTypeCell.classList.toggle('d-none', !info.allowsHalfUnit);
            if (!info.allowsHalfUnit) {
                fullRadio.checked = true;
                unitTypeHidden.value = 'Full';
            }

            updateRowMaxAndHint(rowRefs);
            rowsByProductId.set(String(productId), tr);
            return info;
        }

        function addItemRow() {
            const idx = itemIndex++;
            const fragment = template.content.cloneNode(true);
            const tr = fragment.querySelector('.item-row');

            const select = tr.querySelector('.product-select');
            select.name = `Input.Items[${idx}].ProductId`;

            const qtyInput = tr.querySelector('.qty-input');
            qtyInput.name = `Input.Items[${idx}].Quantity`;

            const uomCell = tr.querySelector('.uom-cell');
            const stockCell = tr.querySelector('.stock-cell');
            const unitTypeCell = tr.querySelector('.unit-type-cell');
            const fullRadio = tr.querySelector('.unit-full-radio');
            const halfRadio = tr.querySelector('.unit-half-radio');
            const effQtyCell = tr.querySelector('.eff-qty-cell');
            fullRadio.name = `unitType-${idx}`;
            halfRadio.name = `unitType-${idx}`;

            const uomHidden = document.createElement('input');
            uomHidden.type = 'hidden';
            uomHidden.name = `Input.Items[${idx}].UnitOfMeasure`;
            tr.appendChild(uomHidden);

            const unitTypeHidden = document.createElement('input');
            unitTypeHidden.type = 'hidden';
            unitTypeHidden.name = `Input.Items[${idx}].UnitType`;
            unitTypeHidden.value = 'Full';
            tr.appendChild(unitTypeHidden);

            const scanFlagHidden = document.createElement('input');
            scanFlagHidden.type = 'hidden';
            scanFlagHidden.name = `Input.Items[${idx}].AddedByBarcodeScan`;
            scanFlagHidden.value = 'false';
            tr.appendChild(scanFlagHidden);

            const scanValueHidden = document.createElement('input');
            scanValueHidden.type = 'hidden';
            scanValueHidden.name = `Input.Items[${idx}].ScannedBarcodeValue`;
            tr.appendChild(scanValueHidden);

            itemsBody.appendChild(tr);
            window.SadaleneSelects.enhance(select);

            const rowRefs = {
                tr, uomCell, stockCell, uomHidden, qtyInput,
                unitTypeCell, fullRadio, halfRadio, effQtyCell, unitTypeHidden
            };

            select.tomselect.on('change', function (productId) {
                applyProductInfo(rowRefs, productId);
            });

            fullRadio.addEventListener('change', function () {
                unitTypeHidden.value = 'Full';
                updateRowMaxAndHint(rowRefs);
            });
            halfRadio.addEventListener('change', function () {
                unitTypeHidden.value = 'Half';
                updateRowMaxAndHint(rowRefs);
            });
            qtyInput.addEventListener('input', function () { updateRowMaxAndHint(rowRefs); });

            tr.querySelector('.remove-item-btn').addEventListener('click', function () {
                if (itemsBody.querySelectorAll('.item-row').length > 1) {
                    for (const [pid, row] of rowsByProductId) if (row === tr) rowsByProductId.delete(pid);
                    tr.remove();
                }
            });

            return {
                tr, select, qtyInput, scanFlagHidden, scanValueHidden,
                applyProductInfo: (productId) => applyProductInfo(rowRefs, productId)
            };
        }

        document.getElementById('addItemBtn').addEventListener('click', () => addItemRow());
        addItemRow();

        // --- Scan Barcode / QR Code ---
        const scanInput = document.getElementById('scanInput');
        const scanFeedback = document.getElementById('scanFeedback');

        function showScanFeedback(message, isError) {
            scanFeedback.textContent = message;
            scanFeedback.className = 'small mt-1 ' + (isError ? 'text-danger' : 'text-success');
        }

        scanInput.addEventListener('keydown', async function (e) {
            if (e.key !== 'Enter') return;
            e.preventDefault();

            const sku = scanInput.value.trim();
            if (!sku) return;

            const response = await fetch(`/api/master/product-by-sku?sku=${encodeURIComponent(sku)}`);
            if (response.status === 404) {
                showScanFeedback(`No product found for SKU "${sku}".`, true);
                scanInput.select();
                return;
            }
            if (!response.ok) {
                showScanFeedback('Something went wrong looking up that SKU.', true);
                return;
            }
            const info = await response.json();

            if (info.stock <= 0) {
                showScanFeedback(`${info.name} (${info.code}) is out of stock.`, true);
                scanInput.select();
                return;
            }

            const existingRow = rowsByProductId.get(String(info.id));
            if (existingRow) {
                const qtyInput = existingRow.querySelector('.qty-input');
                const halfRadio = existingRow.querySelector('.unit-half-radio');
                const unitTypeCell = existingRow.querySelector('.unit-type-cell');
                const mult = (!unitTypeCell.classList.contains('d-none') && halfRadio.checked) ? 0.5 : 1;
                const newQty = (parseFloat(qtyInput.value) || 0) + 1;

                if (newQty * mult > info.stock) {
                    showScanFeedback(`Only ${info.stock} ${info.uom} of ${info.name} available.`, true);
                } else {
                    qtyInput.value = newQty;
                    qtyInput.dispatchEvent(new Event('input'));
                    existingRow.querySelector('input[name$=".AddedByBarcodeScan"]').value = 'true';
                    existingRow.querySelector('input[name$=".ScannedBarcodeValue"]').value = sku;
                    showScanFeedback(`+1 ${info.name} (now ${newQty} ${info.uom}).`, false);
                }
            } else {
                const row = addItemRow();
                row.select.tomselect.setValue(String(info.id), true);
                await row.applyProductInfo(String(info.id));
                row.qtyInput.value = 1;
                row.scanFlagHidden.value = 'true';
                row.scanValueHidden.value = sku;
                showScanFeedback(`Added ${info.name} (${info.code}).`, false);
            }

            scanInput.value = '';
            scanInput.focus();
        });

        scanInput.focus();
    });
</script>
}
