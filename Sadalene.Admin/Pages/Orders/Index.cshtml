@page
@model Sadalene.Admin.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orders";
    ViewData["ActiveMenu"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-bag-check me-2"></i>Orders</h5>
    <div class="d-flex gap-2">
        @foreach (var status in Enum.GetValues<Sadalene.Core.Enums.OrderStatus>())
        {
            <a asp-page="Index" asp-route-status="@status" asp-route-search="@Model.Search"
               class="btn btn-sm @(Model.StatusFilter == status ? "btn-primary" : "btn-outline-secondary")">
                @status
            </a>
        }
        <a asp-page="Index" asp-route-search="@Model.Search" class="btn btn-sm @(Model.StatusFilter == null ? "btn-dark" : "btn-outline-secondary")">All</a>
        <a asp-page="Create" class="btn btn-primary btn-sm ms-2"><i class="bi bi-plus-lg me-1"></i>Add Order</a>
    </div>
</div>

<div class="mb-3" data-live-search data-target="#orders-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by order #, customer or agent..." value="@Model.Search" />
</div>
<div id="orders-table-region">
    <partial name="_OrdersTable" model="Model" />
</div>
