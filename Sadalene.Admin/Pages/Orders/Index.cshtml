@page
@model Sadalene.Admin.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Orders";
    ViewData["ActiveMenu"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-bag-check me-2"></i>Orders</h5>
    <div class="d-flex gap-2">
        @foreach (var status in Enum.GetValues<Sadalene.Core.Enums.OrderStatus>())
        {
            <a asp-page="Index" asp-route-status="@status"
               class="btn btn-sm @(Model.StatusFilter == status ? "btn-primary" : "btn-outline-secondary")">
                @status
            </a>
        }
        <a asp-page="Index" class="btn btn-sm @(Model.StatusFilter == null ? "btn-dark" : "btn-outline-secondary")">All</a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Order #</th><th>Customer</th><th>Agent</th><th>Date</th><th>Items</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders)
                {
                    <tr>
                        <td class="fw-semibold font-monospace"><a asp-page="Details" asp-route-id="@o.Id" class="text-decoration-none">@o.OrderNumber</a></td>
                        <td>@o.Customer.FullName</td>
                        <td class="text-muted small">@(o.Agent?.FullName ?? (o.PlacedByUser != null ? $"Staff: {o.PlacedByUser.FullName}" : "Self"))</td>
                        <td class="text-muted small">@o.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@o.Items.Count</td>
                        <td>
                            <span class="badge @(o.Status == Sadalene.Core.Enums.OrderStatus.Pending ? "bg-warning text-dark" :
                                                 o.Status == Sadalene.Core.Enums.OrderStatus.Confirmed ? "bg-success" :
                                                 o.Status == Sadalene.Core.Enums.OrderStatus.Cancelled ? "bg-danger" :
                                                 o.Status == Sadalene.Core.Enums.OrderStatus.Dispatched ? "bg-info" : "bg-secondary")">
                                @o.Status
                            </span>
                        </td>
                        <td><a asp-page="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                    </tr>
                }
                @if (!Model.Orders.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No orders found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
