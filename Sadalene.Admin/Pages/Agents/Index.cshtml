@page
@model Sadalene.Admin.Pages.Agents.IndexModel
@{
    ViewData["Title"] = "Agents";
    ViewData["ActiveMenu"] = "Agents";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2"></i>Agents</h5>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add Agent</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Phone</th><th>Agent Code</th><th>Orders Placed</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Agents)
                {
                    <tr>
                        <td class="fw-semibold">@a.FullName</td>
                        <td>@a.Phone</td>
                        <td><span class="badge bg-secondary">@(a.AgentCode ?? "—")</span></td>
                        <td>@a.Orders.Count</td>
                        <td><span class="badge @(a.IsActive ? "bg-success" : "bg-secondary")">@(a.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <a asp-page="Delete" asp-route-id="@a.Id" class="btn btn-sm btn-outline-danger ms-1"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
