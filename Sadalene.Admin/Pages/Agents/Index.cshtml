@page
@model Sadalene.Admin.Pages.Agents.IndexModel
@{
    ViewData["Title"] = "Agents";
    ViewData["ActiveMenu"] = "Agents";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2"></i>Agents</h5>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add Agent</a>
</div>

<div class="mb-3" data-live-search data-target="#agents-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by name, phone or agent code..." value="@Model.Search" />
</div>
<div id="agents-table-region">
    <partial name="_AgentsTable" model="Model" />
</div>
