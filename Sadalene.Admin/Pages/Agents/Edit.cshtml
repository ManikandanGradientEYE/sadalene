@page "{id:int}"
@model Sadalene.Admin.Pages.Agents.EditModel
@{
    ViewData["Title"] = "Edit Agent";
    ViewData["ActiveMenu"] = "Agents";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Edit Agent</h5>
</div>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <form method="post" asp-page-handler="Save">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <input type="hidden" asp-for="Input.Id" />
            <div class="mb-3">
                <label asp-for="Input.FullName" class="form-label fw-semibold">Full Name</label>
                <input asp-for="Input.FullName" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Phone" class="form-label fw-semibold">Phone</label>
                <input asp-for="Input.Phone" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Input.Email" type="email" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.AgentCode" class="form-label fw-semibold">Agent Code</label>
                <input asp-for="Input.AgentCode" class="form-control" />
            </div>
            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                </div>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-2"></i>Save</button>
        </form>
    </div>
</div>

<div class="card mt-4" style="max-width:900px">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold mb-0">Customers <span class="badge bg-secondary">@Model.Customers.Count</span></h6>
            <div class="d-flex gap-2">
                @if (Model.Customers.Count > 5)
                {
                    <input type="search" id="customerSearch" class="form-control form-control-sm" placeholder="Search name or phone" style="width:220px" />
                }
                <button class="btn btn-sm btn-primary text-nowrap" type="button" data-bs-toggle="modal" data-bs-target="#addCustomerModal">
                    <i class="bi bi-plus-lg me-1"></i>Add Customer
                </button>
            </div>
        </div>

        @if (Model.Customers.Count == 0)
        {
            <p class="text-muted small mb-0">No customers linked to this agent yet.</p>
        }
        else
        {
            <table class="table table-sm table-hover mb-0" id="customersTable">
                <thead class="table-light"><tr><th>Name</th><th>Phone</th><th>City</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var c in Model.Customers)
                    {
                        <tr>
                            <td>@c.FullName</td>
                            <td>@c.Phone</td>
                            <td>@(c.City ?? "—")</td>
                            <td><span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span></td>
                            <td><a asp-page="/Customers/Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Update details</a></td>
                        </tr>
                    }
                </tbody>
            </table>
            <p id="customerSearchEmpty" class="text-muted small mb-0 mt-2 d-none">No customers match your search.</p>
        }
    </div>
</div>

<div class="modal fade" id="addCustomerModal" tabindex="-1" aria-labelledby="addCustomerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddCustomer">
                <div class="modal-header">
                    <h6 class="modal-title fw-bold" id="addCustomerModalLabel">Add Customer for @Model.Input.FullName</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <input type="hidden" asp-for="NewCustomer.AgentId" value="@Model.Input.Id" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewCustomer.FullName" class="form-label fw-semibold">Full Name</label>
                            <input asp-for="NewCustomer.FullName" class="form-control" />
                            <span asp-validation-for="NewCustomer.FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewCustomer.Phone" class="form-label fw-semibold">Phone</label>
                            <input asp-for="NewCustomer.Phone" class="form-control" />
                            <span asp-validation-for="NewCustomer.Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewCustomer.Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="NewCustomer.Email" type="email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewCustomer.GstNumber" class="form-label fw-semibold">GST Number</label>
                            <input asp-for="NewCustomer.GstNumber" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="NewCustomer.Address" class="form-label fw-semibold">Address</label>
                            <textarea asp-for="NewCustomer.Address" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewCustomer.City" class="form-label fw-semibold">City</label>
                            <input asp-for="NewCustomer.City" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="NewCustomer.State" class="form-label fw-semibold">State</label>
                            <input asp-for="NewCustomer.State" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-2"></i>Add Customer</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('customerSearch')?.addEventListener('input', function () {
            const q = this.value.trim().toLowerCase();
            const rows = document.querySelectorAll('#customersTable tbody tr');
            let visible = 0;
            rows.forEach(row => {
                const match = row.textContent.toLowerCase().includes(q);
                row.classList.toggle('d-none', !match);
                if (match) visible++;
            });
            document.getElementById('customerSearchEmpty')?.classList.toggle('d-none', visible > 0);
        });

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Keys.Any(k => k.StartsWith("NewCustomer")))
        {
            <text>
            new bootstrap.Modal(document.getElementById('addCustomerModal')).show();
            </text>
        }
    </script>
}
