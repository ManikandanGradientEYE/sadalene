@page
@model Sadalene.Admin.Pages.Documents.Challans.IndexModel
@{
    ViewData["Title"] = "Challans";
    ViewData["ActiveMenu"] = "Challans";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text me-2"></i>Challans</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal">
        <i class="bi bi-upload me-1"></i>Upload Challan
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Challan #</th><th>Customer</th><th>Order #</th><th>Date</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Challans)
                {
                    <tr>
                        <td class="fw-semibold font-monospace">@c.ChallanNumber</td>
                        <td>@c.Customer.FullName</td>
                        <td class="text-muted small">@(c.Order?.OrderNumber ?? "—")</td>
                        <td class="text-muted small">@c.ChallanDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Archived")</span></td>
                        <td>
                            <a href="@c.FileUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> View
                            </a>
                            <form method="post" asp-page-handler="Archive" class="d-inline">
                                <input type="hidden" name="id" value="@c.Id" />
                                <button class="btn btn-sm btn-outline-secondary ms-1"><i class="bi bi-archive"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Challans.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">No challans uploaded yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Upload Challan</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Challan Number</label>
                    <input name="challanNumber" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Customer</label>
                    <select name="customerId" class="form-select" required>
                        @foreach (var cust in Model.Customers) { <option value="@cust.Id">@cust.FullName (@cust.Phone)</option> }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Linked Order (optional)</label>
                    <select name="orderId" class="form-select">
                        <option value="">— None —</option>
                        @foreach (var o in Model.Orders) { <option value="@o.Id">@o.OrderNumber — @o.Customer.FullName</option> }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Challan Date</label>
                    <input name="challanDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Challan File (PDF/Image)</label>
                    <input name="file" type="file" class="form-control" accept=".pdf,image/*" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Upload</button>
            </div>
        </form>
    </div></div>
</div>
