@model Sadalene.Admin.Pages.Documents.Invoices.IndexModel

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Invoice #</th><th>Customer</th><th>Order #</th><th>Date</th><th>Amount</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var inv in Model.Invoices.Items)
                {
                    <tr>
                        <td class="fw-semibold font-monospace">@inv.InvoiceNumber</td>
                        <td>@inv.Customer.FullName</td>
                        <td class="text-muted small">@(inv.Order?.OrderNumber ?? "—")</td>
                        <td class="text-muted small">@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                        <td>@(inv.TotalAmount.HasValue ? $"₹{inv.TotalAmount:N2}" : "—")</td>
                        <td><span class="badge @(inv.IsActive ? "bg-success" : "bg-secondary")">@(inv.IsActive ? "Active" : "Archived")</span></td>
                        <td>
                            <a href="@inv.FileUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> View
                            </a>
                            <form method="post" asp-page-handler="Archive" class="d-inline">
                                <input type="hidden" name="id" value="@inv.Id" />
                                <button class="btn btn-sm btn-outline-secondary ms-1"><i class="bi bi-archive"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (Model.Invoices.Items.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No invoices found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.Invoices" />
</div>
