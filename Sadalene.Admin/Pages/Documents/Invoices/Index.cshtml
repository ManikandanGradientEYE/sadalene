@page
@model Sadalene.Admin.Pages.Documents.Invoices.IndexModel
@{
    ViewData["Title"] = "Invoices";
    ViewData["ActiveMenu"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-receipt me-2"></i>Invoices</h5>
    <div>
        <a asp-page="Import" class="btn btn-outline-secondary btn-sm me-2"><i class="bi bi-upload me-1"></i>Import</a>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal">
            <i class="bi bi-file-earmark-plus me-1"></i>Upload Invoice
        </button>
    </div>
</div>

<div class="mb-3" data-live-search data-target="#invoices-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by invoice # or customer..." value="@Model.Search" />
</div>
<div id="invoices-table-region">
    <partial name="_InvoicesTable" model="Model" />
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Upload Invoice</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Invoice Number</label>
                    <input name="invoiceNumber" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Customer</label>
                    <select id="uploadCustomerSelect" name="customerId" class="form-select" required>
                        <option value="">— Select Customer —</option>
                        @foreach (var c in Model.Customers) { <option value="@c.Id">@c.FullName (@c.Phone)</option> }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Linked Order (optional)</label>
                    <select id="uploadOrderSelect" name="orderId" class="form-select">
                        <option value="">— Select Customer first —</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Invoice Date</label>
                    <input name="invoiceDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Total Amount</label>
                    <input name="totalAmount" type="number" step="0.01" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Invoice File (PDF/Image)</label>
                    <input name="file" type="file" class="form-control" accept=".pdf,image/*" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Upload</button>
            </div>
        </form>
    </div></div>
</div>

@section Scripts {
    <script>
        (function () {
            const uploadModal = document.getElementById('uploadModal');
            const uploadCustomerSelect = document.getElementById('uploadCustomerSelect');
            const uploadOrderSelect = document.getElementById('uploadOrderSelect');
            let wired = false;

            // Selects inside a modal are only Tom-Select-enhanced once the modal is first shown
            // (select-enhance.js), so wiring the cascade here — and re-enhancing defensively —
            // avoids depending on listener registration order between the two scripts.
            uploadModal.addEventListener('shown.bs.modal', function () {
                window.SadaleneSelects.enhance(uploadCustomerSelect);
                window.SadaleneSelects.enhance(uploadOrderSelect);

                if (wired) return;
                wired = true;

                uploadCustomerSelect.tomselect.on('change', async function (customerId) {
                    uploadOrderSelect.tomselect.clear(true);
                    uploadOrderSelect.tomselect.clearOptions();
                    uploadOrderSelect.tomselect.addOption({ value: '', text: customerId ? 'Loading...' : '— Select Customer first —' });
                    uploadOrderSelect.tomselect.refreshOptions(false);

                    if (!customerId) return;

                    const data = await fetch(`/api/master/invoice-orders-for-customer?customerId=${customerId}`).then(r => r.json());
                    uploadOrderSelect.tomselect.clearOptions();
                    uploadOrderSelect.tomselect.addOption({ value: '', text: data.length ? '— None —' : 'No unlinked orders for this customer' });
                    data.forEach(o => uploadOrderSelect.tomselect.addOption({ value: String(o.id), text: o.orderNumber }));
                    uploadOrderSelect.tomselect.refreshOptions(false);
                });
            });
        })();
    </script>
}
