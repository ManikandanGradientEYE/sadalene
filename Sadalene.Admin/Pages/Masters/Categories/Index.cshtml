@page
@model Sadalene.Admin.Pages.Masters.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
    ViewData["ActiveMenu"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-tag me-2"></i>Categories</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Category
    </button>
</div>

@if (!Model.AllDivisions.Any())
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        No active divisions found. <a asp-page="/Masters/Divisions/Index">Create a Division first</a> before adding categories.
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Division</th><th>Category</th><th>Description</th><th>Sub-Categories</th><th>Order</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Categories)
                {
                    <tr>
                        <td>
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 py-1 px-2">
                                @c.Division.Name
                            </span>
                        </td>
                        <td class="fw-semibold">@c.Name</td>
                        <td class="text-muted small">@c.Description</td>
                        <td>@c.SubCategories.Count</td>
                        <td>@c.DisplayOrder</td>
                        <td><span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@c.Id">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@c.Id" />
                                <button class="btn btn-sm @(c.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-1">
                                    <i class="bi @(c.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>

                    <!-- Edit Modal -->
                    <div class="modal fade" id="editModal-@c.Id" tabindex="-1">
                        <div class="modal-dialog"><div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit Category</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" asp-page-handler="Edit">
                                <div class="modal-body">
                                    <input type="hidden" name="Id" value="@c.Id" />
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Division</label>
                                        <select name="DivisionId" class="form-select" required>
                                            @foreach (var div in Model.AllDivisions)
                                            {
                                                <option value="@div.Id" selected="@(div.Id == c.DivisionId)">@div.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Category Name</label>
                                        <input name="Name" value="@c.Name" class="form-control" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Description</label>
                                        <input name="Description" value="@c.Description" class="form-control" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Display Order</label>
                                        <input name="DisplayOrder" value="@c.DisplayOrder" type="number" class="form-control" />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                </div>
                            </form>
                        </div></div>
                    </div>
                }
                @if (!Model.Categories.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No categories yet. Add one above.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title">Add Category</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form method="post" asp-page-handler="Add">
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Division <span class="text-danger">*</span></label>
                    <select name="DivisionId" class="form-select" required>
                        <option value="">— Select Division —</option>
                        @foreach (var div in Model.AllDivisions)
                        {
                            <option value="@div.Id">@div.Name</option>
                        }
                    </select>
                    <div class="form-text">Category will belong to this division.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Category Name <span class="text-danger">*</span></label>
                    <input name="Name" class="form-control" placeholder="e.g. Saree, Suiting" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <input name="Description" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Display Order</label>
                    <input name="DisplayOrder" type="number" value="0" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Add Category</button>
            </div>
        </form>
    </div></div>
</div>
