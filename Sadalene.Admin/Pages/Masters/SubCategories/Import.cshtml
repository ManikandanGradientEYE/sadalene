@page
@model Sadalene.Admin.Pages.Masters.SubCategories.ImportModel
@{
    ViewData["Title"] = "Import Sub-Categories";
    ViewData["ActiveMenu"] = "SubCategories";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Import Sub-Categories from Excel</h5>
</div>

<div class="card mb-4" style="max-width:700px">
    <div class="card-body">
        <p class="text-muted small mb-3">
            Download the template, fill in your sub-categories, then upload it below. Columns marked with
            <span class="text-danger fw-semibold">*</span> are required.
        </p>
        <p class="text-muted small mb-3">
            <i class="bi bi-info-circle me-1"></i><strong>Division</strong> and <strong>Category</strong> must already
            exist together — <a asp-page="/Masters/Categories/Import">import Categories first</a> if needed.
            <strong>Name</strong> must be unique within its category. <strong>UOM</strong> (if given) must already exist.
            Rows that clash with an existing sub-category (or another row in the same file) are skipped.
            <strong>Description</strong> and <strong>DisplayOrder</strong> are optional. Images aren't set via import —
            add them individually afterward if needed.
        </p>
        <a asp-page-handler="Template" class="btn btn-outline-secondary btn-sm mb-4">
            <i class="bi bi-download me-1"></i>Download Excel Template
        </a>

        <form method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label fw-semibold">Excel File</label>
                <input type="file" name="file" class="form-control" accept=".xlsx" required />
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-2"></i>Import</button>
        </form>
    </div>
</div>

@if (Model.ImportedCount > 0 || Model.Errors.Count > 0)
{
    <div class="card" style="max-width:700px">
        <div class="card-body">
            <h6 class="fw-bold mb-3">Import Result</h6>
            @if (Model.ImportedCount > 0)
            {
                <p class="text-success mb-2"><i class="bi bi-check-circle me-1"></i>@Model.ImportedCount sub-category(ies) imported successfully.</p>
            }
            @if (Model.Errors.Count > 0)
            {
                <p class="text-danger fw-semibold mb-2">@Model.Errors.Count row(s) skipped:</p>
                <ul class="text-danger small mb-0">
                    @foreach (var e in Model.Errors)
                    {
                        <li>@e</li>
                    }
                </ul>
            }
        </div>
    </div>
}
