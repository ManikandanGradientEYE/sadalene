@model Sadalene.Admin.Pages.Masters.SubCategories.IndexModel

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Image</th><th>Division</th><th>Category</th><th>Sub-Category</th>
                    <th>UOM</th><th>Description</th><th>Order</th><th>Status</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.SubCategories.Items)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(s.ImageUrl))
                            {
                                <img src="@s.ImageUrl" alt="@s.Name" class="rounded border" style="width:40px;height:40px;object-fit:cover" />
                            }
                            else
                            {
                                <span class="d-inline-flex align-items-center justify-content-center rounded border bg-light text-muted"
                                      style="width:40px;height:40px">
                                    <i class="bi bi-image"></i>
                                </span>
                            }
                        </td>
                        <td class="text-muted small">
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                @s.Category.Division?.Name
                            </span>
                        </td>
                        <td class="text-muted small">@s.Category.Name</td>
                        <td class="fw-semibold">@s.Name</td>
                        <td>
                            @if (s.UomMaster != null)
                            {
                                <span class="badge bg-opacity-15 text-info border border-info border-opacity-25">
                                    @s.UomMaster.Name
                                    @if (!string.IsNullOrEmpty(s.UomMaster.Abbreviation))
                                    { <text>(@s.UomMaster.Abbreviation)</text> }
                                </span>
                            }
                            else { <span class="text-muted small">—</span> }
                        </td>
                        <td class="text-muted small">@s.Description</td>
                        <td>@s.DisplayOrder</td>
                        <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@s.Id">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@s.Id" />
                                <button class="btn btn-sm @(s.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-1">
                                    <i class="bi @(s.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>

                    <!-- Edit Modal -->
                    <div class="modal fade" id="editModal-@s.Id" tabindex="-1">
                        <div class="modal-dialog"><div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit Sub-Category</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" asp-page-handler="Edit" enctype="multipart/form-data">
                                <div class="modal-body">
                                    <input type="hidden" name="Id" value="@s.Id" />
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Category</label>
                                        <select name="CategoryId" class="form-select">
                                            @foreach (var c in Model.AllCategories)
                                            {
                                                <option value="@c.Id" selected="@(c.Id == s.CategoryId)">
                                                    @c.Division?.Name › @c.Name
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Sub-Category Name <span class="text-danger">*</span></label>
                                        <input name="Name" value="@s.Name" class="form-control" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Unit of Measure (UOM)</label>
                                        <select name="UomMasterId" class="form-select">
                                            <option value="0">— None —</option>
                                            @foreach (var uom in Model.AllUoms)
                                            {
                                                <option value="@uom.Id" selected="@(uom.Id == s.UomMasterId)">
                                                    @uom.Name @(!string.IsNullOrEmpty(uom.Abbreviation) ? $"({uom.Abbreviation})" : "")
                                                </option>
                                            }
                                        </select>
                                        <div class="form-text">Auto-fills in Product when this sub-category is selected.</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Description</label>
                                        <input name="Description" value="@s.Description" class="form-control" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Image</label>
                                        @if (!string.IsNullOrEmpty(s.ImageUrl))
                                        {
                                            <div class="mb-2">
                                                <img src="@s.ImageUrl" alt="@s.Name" class="rounded border" style="width:64px;height:64px;object-fit:cover" />
                                            </div>
                                        }
                                        <input name="imageFile" type="file" class="form-control" accept="image/*" />
                                        <div class="form-text">Leave blank to keep the current image.</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Display Order</label>
                                        <input name="DisplayOrder" value="@s.DisplayOrder" type="number" class="form-control" />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                </div>
                            </form>
                        </div></div>
                    </div>
                }
                @if (Model.SubCategories.Items.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No sub-categories found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.SubCategories" />
</div>
