@page
@model Sadalene.Admin.Pages.Masters.SubCategories.IndexModel
@{
    ViewData["Title"] = "Sub-Categories";
    ViewData["ActiveMenu"] = "SubCategories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-tags me-2"></i>Sub-Categories</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Sub-Category
    </button>
</div>

<div class="mb-3" data-live-search data-target="#subcategories-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by name or category..." value="@Model.Search" />
</div>
<div id="subcategories-table-region">
    <partial name="_SubCategoriesTable" model="Model" />
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title">Add Sub-Category</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form method="post" asp-page-handler="Add" enctype="multipart/form-data">
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                    <select name="CategoryId" class="form-select" required>
                        <option value="">— Select Category —</option>
                        @foreach (var c in Model.AllCategories)
                        {
                            <option value="@c.Id">@c.Division?.Name › @c.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Sub-Category Name <span class="text-danger">*</span></label>
                    <input name="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Unit of Measure (UOM)</label>
                    <select name="UomMasterId" class="form-select">
                        <option value="0">— None —</option>
                        @foreach (var uom in Model.AllUoms)
                        {
                            <option value="@uom.Id">
                                @uom.Name @(!string.IsNullOrEmpty(uom.Abbreviation) ? $"({uom.Abbreviation})" : "")
                            </option>
                        }
                    </select>
                    <div class="form-text">Auto-fills in Product when this sub-category is selected.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <input name="Description" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Image</label>
                    <input name="imageFile" type="file" class="form-control" accept="image/*" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Display Order</label>
                    <input name="DisplayOrder" type="number" value="0" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Add</button>
            </div>
        </form>
    </div></div>
</div>
