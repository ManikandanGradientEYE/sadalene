@page
@model Sadalene.Admin.Pages.Masters.SubCategories.IndexModel
@{
    ViewData["Title"] = "Sub-Categories";
    ViewData["ActiveMenu"] = "SubCategories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-tags me-2"></i>Sub-Categories</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Sub-Category
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Category</th><th>Sub-Category</th><th>Description</th><th>Order</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var s in Model.SubCategories)
                {
                    <tr>
                        <td class="text-muted small">@s.Category.Name</td>
                        <td class="fw-semibold">@s.Name</td>
                        <td class="text-muted">@s.Description</td>
                        <td>@s.DisplayOrder</td>
                        <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@s.Id"><i class="bi bi-pencil"></i></button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@s.Id" />
                                <button class="btn btn-sm @(s.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-1">
                                    <i class="bi @(s.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <div class="modal fade" id="editModal-@s.Id" tabindex="-1">
                        <div class="modal-dialog"><div class="modal-content">
                            <div class="modal-header"><h5 class="modal-title">Edit Sub-Category</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                            <form method="post" asp-page-handler="Edit">
                                <div class="modal-body">
                                    <input type="hidden" name="Id" value="@s.Id" />
                                    <div class="mb-3"><label class="form-label fw-semibold">Category</label>
                                        <select name="CategoryId" class="form-select">
                                            @foreach (var c in Model.AllCategories)
                                            {
                                                <option value="@c.Id" selected="@(c.Id == s.CategoryId)">@c.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3"><label class="form-label fw-semibold">Name</label><input name="Name" value="@s.Name" class="form-control" required /></div>
                                    <div class="mb-3"><label class="form-label fw-semibold">Description</label><input name="Description" value="@s.Description" class="form-control" /></div>
                                    <div class="mb-3"><label class="form-label fw-semibold">Display Order</label><input name="DisplayOrder" value="@s.DisplayOrder" type="number" class="form-control" /></div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                </div>
                            </form>
                        </div></div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Add Sub-Category</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <form method="post" asp-page-handler="Add">
            <div class="modal-body">
                <div class="mb-3"><label class="form-label fw-semibold">Category</label>
                    <select name="CategoryId" class="form-select" required>
                        @foreach (var c in Model.AllCategories) { <option value="@c.Id">@c.Name</option> }
                    </select>
                </div>
                <div class="mb-3"><label class="form-label fw-semibold">Name</label><input name="Name" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label fw-semibold">Description</label><input name="Description" class="form-control" /></div>
                <div class="mb-3"><label class="form-label fw-semibold">Display Order</label><input name="DisplayOrder" type="number" value="0" class="form-control" /></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Add</button>
            </div>
        </form>
    </div></div>
</div>
