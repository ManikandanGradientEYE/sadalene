@page
@model Sadalene.Admin.Pages.Masters.ProductTypes.IndexModel
@{
    ViewData["Title"] = "Product Types";
    ViewData["ActiveMenu"] = "ProductTypes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Product Types</h5>
    <div>
        <a asp-page="Import" class="btn btn-outline-secondary btn-sm me-2"><i class="bi bi-upload me-1"></i>Import</a>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="bi bi-plus-lg me-1"></i>Add Type
        </button>
    </div>
</div>

<div class="mb-3" data-live-search data-target="#producttypes-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by name..." value="@Model.Search" />
</div>
<div id="producttypes-table-region">
    <partial name="_ProductTypesTable" model="Model" />
</div>

<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Add Product Type</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <form method="post" asp-page-handler="Add">
            <div class="modal-body">
                <div class="mb-3"><label class="form-label fw-semibold">Name</label><input name="Name" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label fw-semibold">Description</label><input name="Description" class="form-control" /></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Add</button>
            </div>
        </form>
    </div></div>
</div>
