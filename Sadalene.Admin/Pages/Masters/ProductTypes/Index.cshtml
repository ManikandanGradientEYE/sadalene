@page
@model Sadalene.Admin.Pages.Masters.ProductTypes.IndexModel
@{
    ViewData["Title"] = "Product Types";
    ViewData["ActiveMenu"] = "ProductTypes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Product Types</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Type
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Description</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Types)
                {
                    <tr>
                        <td class="fw-semibold">@t.Name</td>
                        <td class="text-muted">@t.Description</td>
                        <td><span class="badge @(t.IsActive ? "bg-success" : "bg-secondary")">@(t.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@t.Id"><i class="bi bi-pencil"></i></button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@t.Id" />
                                <button class="btn btn-sm @(t.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-1">
                                    <i class="bi @(t.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    <div class="modal fade" id="editModal-@t.Id" tabindex="-1">
                        <div class="modal-dialog"><div class="modal-content">
                            <div class="modal-header"><h5 class="modal-title">Edit Type</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                            <form method="post" asp-page-handler="Edit">
                                <div class="modal-body">
                                    <input type="hidden" name="Id" value="@t.Id" />
                                    <div class="mb-3"><label class="form-label fw-semibold">Name</label><input name="Name" value="@t.Name" class="form-control" required /></div>
                                    <div class="mb-3"><label class="form-label fw-semibold">Description</label><input name="Description" value="@t.Description" class="form-control" /></div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                </div>
                            </form>
                        </div></div>
                    </div>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Add Product Type</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <form method="post" asp-page-handler="Add">
            <div class="modal-body">
                <div class="mb-3"><label class="form-label fw-semibold">Name</label><input name="Name" class="form-control" required /></div>
                <div class="mb-3"><label class="form-label fw-semibold">Description</label><input name="Description" class="form-control" /></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Add</button>
            </div>
        </form>
    </div></div>
</div>
