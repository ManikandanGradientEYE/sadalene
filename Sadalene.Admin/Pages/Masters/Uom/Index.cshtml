@page
@model Sadalene.Admin.Pages.Masters.Uom.IndexModel
@{
    ViewData["Title"] = "Unit of Measure";
    ViewData["ActiveMenu"] = "UomMaster";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-rulers me-2"></i>Unit of Measure (UOM)</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add UOM
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th><th>Abbreviation</th><th>Description</th><th>Status</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.UomList)
                {
                    <tr>
                        <td class="fw-semibold">@u.Name</td>
                        <td>
                            @if (!string.IsNullOrEmpty(u.Abbreviation))
                            {
                                <span class="badge bg-secondary bg-opacity-75">@u.Abbreviation</span>
                            }
                        </td>
                        <td class="text-muted small">@u.Description</td>
                        <td>
                            <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                @(u.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@u.Id">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@u.Id" />
                                <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-1">
                                    <i class="bi @(u.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>

                    <!-- Edit Modal -->
                    <div class="modal fade" id="editModal-@u.Id" tabindex="-1">
                        <div class="modal-dialog"><div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit UOM</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" asp-page-handler="Edit">
                                <div class="modal-body">
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                                        <input name="Name" value="@u.Name" class="form-control" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Abbreviation</label>
                                        <input name="Abbreviation" value="@u.Abbreviation" class="form-control" placeholder="e.g. Bx, Tk, Mtr" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Description</label>
                                        <input name="Description" value="@u.Description" class="form-control" />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                </div>
                            </form>
                        </div></div>
                    </div>
                }
                @if (!Model.UomList.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No units of measure added yet. Add one to get started.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title">Add Unit of Measure</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form method="post" asp-page-handler="Add">
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                    <input name="Name" class="form-control" placeholder="e.g. Box, Taka, Meter, No. of Pieces" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Abbreviation</label>
                    <input name="Abbreviation" class="form-control" placeholder="e.g. Bx, Tk, Mtr, Pcs" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <input name="Description" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Add UOM</button>
            </div>
        </form>
    </div></div>
</div>
