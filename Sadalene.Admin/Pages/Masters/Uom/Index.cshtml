@page
@model Sadalene.Admin.Pages.Masters.Uom.IndexModel
@{
    ViewData["Title"] = "Unit of Measure";
    ViewData["ActiveMenu"] = "UomMaster";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-rulers me-2"></i>Unit of Measure (UOM)</h5>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add UOM
    </button>
</div>

<div class="mb-3" data-live-search data-target="#uom-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by name or abbreviation..." value="@Model.Search" />
</div>
<div id="uom-table-region">
    <partial name="_UomTable" model="Model" />
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title">Add Unit of Measure</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form method="post" asp-page-handler="Add">
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                    <input name="Name" class="form-control" placeholder="e.g. Box, Taka, Meter, No. of Pieces" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Abbreviation</label>
                    <input name="Abbreviation" class="form-control" placeholder="e.g. Bx, Tk, Mtr, Pcs" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <input name="Description" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary btn-sm">Add UOM</button>
            </div>
        </form>
    </div></div>
</div>
