@model Sadalene.Admin.Pages.Masters.Uom.IndexModel

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th><th>Abbreviation</th><th>Description</th><th>Half Unit</th><th>Status</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.UomList.Items)
                {
                    <tr>
                        <td class="fw-semibold">@u.Name</td>
                        <td>
                            @if (!string.IsNullOrEmpty(u.Abbreviation))
                            {
                                <span class="badge bg-secondary bg-opacity-75">@u.Abbreviation</span>
                            }
                        </td>
                        <td class="text-muted small">@u.Description</td>
                        <td>
                            @if (u.AllowsHalfUnit)
                            {
                                <span class="badge bg-info-subtle text-info-emphasis">Allowed</span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                @(u.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@u.Id">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@u.Id" />
                                <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-1">
                                    <i class="bi @(u.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>

                    <!-- Edit Modal -->
                    <div class="modal fade" id="editModal-@u.Id" tabindex="-1">
                        <div class="modal-dialog"><div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit UOM</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" asp-page-handler="Edit">
                                <div class="modal-body">
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                                        <input name="Name" value="@u.Name" class="form-control" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Abbreviation</label>
                                        <input name="Abbreviation" value="@u.Abbreviation" class="form-control" placeholder="e.g. Bx, Tk, Mtr" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Description</label>
                                        <input name="Description" value="@u.Description" class="form-control" />
                                    </div>
                                    <div class="form-check mb-2">
                                        <input type="checkbox" name="allowsHalfUnit" value="true" class="form-check-input"
                                               id="editAllowsHalfUnit-@u.Id" checked="@u.AllowsHalfUnit" />
                                        <label class="form-check-label" for="editAllowsHalfUnit-@u.Id">Allows Half Unit</label>
                                        <div class="form-text">Lets staff order half of this unit (e.g. Half Lump) when placing an order.</div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                </div>
                            </form>
                        </div></div>
                    </div>
                }
                @if (Model.UomList.Items.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No units of measure found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.UomList" />
</div>
