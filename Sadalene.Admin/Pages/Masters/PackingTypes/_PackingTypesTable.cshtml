@model Sadalene.Admin.Pages.Masters.PackingTypes.IndexModel

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Description</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model.PackingTypes.Items)
                {
                    <tr>
                        <td class="fw-semibold">@p.Name</td>
                        <td class="text-muted small">@p.Description</td>
                        <td>
                            <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">
                                @(p.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@p.Id">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm @(p.IsActive ? "btn-outline-warning" : "btn-outline-success") ms-1">
                                    <i class="bi @(p.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>

                    <div class="modal fade" id="editModal-@p.Id" tabindex="-1">
                        <div class="modal-dialog"><div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit Packing Type</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" asp-page-handler="Edit">
                                <div class="modal-body">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                                        <input name="Name" value="@p.Name" class="form-control" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Description</label>
                                        <input name="Description" value="@p.Description" class="form-control" />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                </div>
                            </form>
                        </div></div>
                    </div>
                }
                @if (Model.PackingTypes.Items.Count == 0)
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">No packing types found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.PackingTypes" />
</div>
