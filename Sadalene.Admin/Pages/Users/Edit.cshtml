@page "{id:int}"
@model Sadalene.Admin.Pages.Users.EditModel
@{
    ViewData["Title"] = "Edit User";
    ViewData["ActiveMenu"] = "Users";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Edit User</h5>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
            <div class="mb-3">
                <label asp-for="Input.FullName" class="form-label fw-semibold">Full Name</label>
                <input asp-for="Input.FullName" class="form-control" />
                <span asp-validation-for="Input.FullName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Phone" class="form-label fw-semibold">Phone</label>
                <input asp-for="Input.Phone" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Input.Email" type="email" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Role" class="form-label fw-semibold">Role</label>
                <select asp-for="Input.Role" class="form-select" asp-items="Html.GetEnumSelectList<Sadalene.Core.Enums.UserRole>()"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Input.NewPassword" class="form-label fw-semibold">New Password <span class="text-muted fw-normal">(leave blank to keep current)</span></label>
                <input asp-for="Input.NewPassword" type="password" class="form-control" />
            </div>
            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="Input.IsActive" class="form-check-label">Active</label>
                </div>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-2"></i>Save Changes</button>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
