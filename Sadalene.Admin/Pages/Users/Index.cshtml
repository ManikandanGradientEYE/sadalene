@page
@model Sadalene.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Staff & Admin Users";
    ViewData["ActiveMenu"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-person-gear me-2"></i>Staff & Admin Users</h5>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add User</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Phone</th><th>Email</th><th>Role</th><th>Last Login</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr>
                        <td class="fw-semibold">@u.FullName</td>
                        <td>@u.Phone</td>
                        <td class="text-muted">@u.Email</td>
                        <td><span class="badge @(u.Role == Sadalene.Core.Enums.UserRole.Admin ? "bg-danger" : "bg-secondary")">@u.Role</span></td>
                        <td class="text-muted small">@(u.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</td>
                        <td><span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">@(u.IsActive ? "Active" : "Inactive")</span></td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <a asp-page="Delete" asp-route-id="@u.Id" class="btn btn-sm btn-outline-danger ms-1"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
