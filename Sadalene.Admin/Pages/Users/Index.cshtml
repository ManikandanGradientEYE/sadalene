@page
@model Sadalene.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Staff & Admin Users";
    ViewData["ActiveMenu"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-person-gear me-2"></i>Staff & Admin Users</h5>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add User</a>
</div>

<div class="mb-3" data-live-search data-target="#users-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by name, phone or email..." value="@Model.Search" />
</div>
<div id="users-table-region">
    <partial name="_UsersTable" model="Model" />
</div>
