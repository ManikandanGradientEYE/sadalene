@page "{id:int}"
@model Sadalene.Admin.Pages.Users.DeleteModel
@{
    ViewData["Title"] = "Delete User";
    ViewData["ActiveMenu"] = "Users";
}

<div class="card" style="max-width:480px">
    <div class="card-header bg-danger text-white fw-semibold">Confirm Delete</div>
    <div class="card-body">
        <p>Are you sure you want to delete <strong>@Model.UserName</strong>?</p>
        <form method="post">
            <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
