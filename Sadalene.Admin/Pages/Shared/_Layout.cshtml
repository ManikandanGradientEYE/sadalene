<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Sadalene Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        :root { --sidebar-width: 260px; --topbar-height: 56px; --primary: #1a5276; }
        body { background: #f4f6f9; }
        #sidebar {
            width: var(--sidebar-width); position: fixed; top: 0; left: 0;
            height: 100vh; background: var(--primary); color: #fff;
            overflow-y: auto; z-index: 1000; transition: transform .25s;
        }
        #sidebar .brand { padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,.15); }
        #sidebar .brand h5 { margin: 0; font-weight: 700; letter-spacing: .5px; }
        #sidebar .brand small { opacity: .65; font-size: .75rem; }
        #sidebar .nav-section { padding: .5rem 1rem .15rem; font-size: .7rem;
            text-transform: uppercase; letter-spacing: 1px; opacity: .55; }
        #sidebar .nav-link { color: rgba(255,255,255,.8); padding: .5rem 1.25rem;
            border-radius: 6px; margin: 1px 8px; display: flex; align-items: center; gap: .6rem; }
        #sidebar .nav-link:hover, #sidebar .nav-link.active { background: rgba(255,255,255,.15); color: #fff; }
        #topbar { margin-left: var(--sidebar-width); height: var(--topbar-height);
            background: #fff; border-bottom: 1px solid #e2e8f0;
            display: flex; align-items: center; padding: 0 1.5rem; position: sticky; top:0; z-index: 900; }
        #main { margin-left: var(--sidebar-width); padding: 1.5rem; min-height: calc(100vh - var(--topbar-height)); }
        .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,.08); border-radius: 10px; }
        .card-header { background: #fff; border-bottom: 1px solid #f0f0f0; font-weight: 600; border-radius: 10px 10px 0 0 !important; }
        .table th { font-size: .82rem; text-transform: uppercase; letter-spacing: .5px; color: #6c757d; }
        .badge-pill { border-radius: 50px; }
        .stat-card { border-radius: 12px; padding: 1.25rem 1.5rem; color: #fff; }
        @@media (max-width: 768px) {
            #sidebar { transform: translateX(-100%); }
            #sidebar.show { transform: translateX(0); }
            #topbar, #main { margin-left: 0; }
        }
    </style>
</head>
<body>

<!-- Sidebar -->
<nav id="sidebar">
    <div class="brand">
        <h5><i class="bi bi-layout-text-sidebar-reverse me-2"></i>Sadalene</h5>
        <small>Admin Panel</small>
    </div>

    <div class="mt-2">
        <div class="nav-section">Main</div>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Dashboard" ? "active" : "")" asp-page="/Index">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-section mt-2">Orders</div>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Orders" ? "active" : "")" asp-page="/Orders/Index">
            <i class="bi bi-bag-check"></i> Orders
        </a>

        <div class="nav-section mt-2">Catalog</div>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Products" ? "active" : "")" asp-page="/Products/Index">
            <i class="bi bi-grid"></i> Products
        </a>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Inventory" ? "active" : "")" asp-page="/Inventory/Index">
            <i class="bi bi-boxes"></i> Inventory
        </a>

        <div class="nav-section mt-2">Documents</div>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Invoices" ? "active" : "")" asp-page="/Documents/Invoices/Index">
            <i class="bi bi-receipt"></i> Invoices
        </a>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Challans" ? "active" : "")" asp-page="/Documents/Challans/Index">
            <i class="bi bi-file-earmark-text"></i> Challans
        </a>

        <div class="nav-section mt-2">Users</div>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Customers" ? "active" : "")" asp-page="/Customers/Index">
            <i class="bi bi-people"></i> Customers
        </a>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Agents" ? "active" : "")" asp-page="/Agents/Index">
            <i class="bi bi-person-badge"></i> Agents
        </a>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Users" ? "active" : "")" asp-page="/Users/Index">
            <i class="bi bi-person-gear"></i> Staff / Admin
        </a>

        <div class="nav-section mt-2">Masters</div>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Divisions" ? "active" : "")" asp-page="/Masters/Divisions/Index">
            <i class="bi bi-diagram-3"></i> Divisions
        </a>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "Categories" ? "active" : "")" asp-page="/Masters/Categories/Index">
            <i class="bi bi-tag"></i> Categories
        </a>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "SubCategories" ? "active" : "")" asp-page="/Masters/SubCategories/Index">
            <i class="bi bi-tags"></i> Sub-Categories
        </a>
        <a class="nav-link @(ViewData["ActiveMenu"]?.ToString() == "ProductTypes" ? "active" : "")" asp-page="/Masters/ProductTypes/Index">
            <i class="bi bi-list-ul"></i> Product Types
        </a>
    </div>
</nav>

<!-- Topbar -->
<div id="topbar">
    <button class="btn btn-sm btn-outline-secondary d-md-none me-3" onclick="document.getElementById('sidebar').classList.toggle('show')">
        <i class="bi bi-list"></i>
    </button>
    <span class="fw-semibold text-muted">@ViewData["Title"]</span>
    <div class="ms-auto d-flex align-items-center gap-3">
        <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>@User.Identity?.Name</span>
        <a asp-page="/Auth/Logout" class="btn btn-sm btn-outline-danger"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
</div>

<!-- Main Content -->
<div id="main">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
