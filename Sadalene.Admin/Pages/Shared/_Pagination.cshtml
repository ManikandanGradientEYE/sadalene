@using Microsoft.AspNetCore.WebUtilities
@model Sadalene.Core.Common.IPagedResult
@functions {
    string PageUrl(int p)
    {
        var q = Context.Request.Query
            .Where(kv => !string.Equals(kv.Key, "pageNumber", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(kv => kv.Key, kv => (string?)kv.Value.ToString());
        q["pageNumber"] = p.ToString();
        return QueryHelpers.AddQueryString(Context.Request.Path, q);
    }
}
@if (Model.TotalCount > 0)
{
    var start = Math.Max(1, Model.Page - 2);
    var end = Math.Min(Model.TotalPages, start + 4);
    start = Math.Max(1, end - 4);
    var from = (Model.Page - 1) * Model.PageSize + 1;
    var to = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 px-3 py-2 border-top">
        <small class="text-muted">Showing @from&ndash;@to of @Model.TotalCount</small>
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@PageUrl(Model.Page - 1)">Previous</a>
                    </li>
                    @for (var i = start; i <= end; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" href="@PageUrl(i)">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@PageUrl(Model.Page + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
}
