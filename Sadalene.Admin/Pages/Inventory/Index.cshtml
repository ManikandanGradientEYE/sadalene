<!-- Shared Adjust Modal -->
<div class="modal fade" id="adjustModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-sliders me-2"></i>Adjust Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Adjust">
                <div class="modal-body">
                    <input type="hidden" name="productId" id="adjustProductId" />

                    <div class="mb-3">
                        <div class="fw-semibold" id="adjustProductName"></div>
                        <div class="text-muted small">
                            Current stock: <strong id="adjustCurrentQty"></strong>
                            <span id="adjustUom" class="ms-1 text-info"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Adjustment Type</label>
                        <div class="d-flex gap-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="adjustType" id="typeAdd" value="Add" checked />
                                <label class="form-check-label text-success fw-semibold" for="typeAdd">
                                    <i class="bi bi-plus-circle"></i> Add
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="adjustType" id="typeSub" value="Subtract" />
                                <label class="form-check-label text-danger fw-semibold" for="typeSub">
                                    <i class="bi bi-dash-circle"></i> Subtract
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="adjustType" id="typeSet" value="Set" />
                                <label class="form-check-label text-primary fw-semibold" for="typeSet">
                                    <i class="bi bi-pencil"></i> Set to
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Quantity <span id="adjustTypeLabel" class="text-muted fw-normal"></span></label>
                        <input type="number" name="quantity" class="form-control" step="0.001" min="0" required placeholder="0" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-semibold">Reason <span class="text-muted fw-normal small">(optional)</span></label>
                        <input type="text" name="reason" class="form-control" placeholder="e.g. Physical count, Purchase receipt, Damaged" maxlength="500" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-lg me-1"></i>Apply</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('adjustModal').addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        document.getElementById('adjustProductId').value  = btn.dataset.productId;
        document.getElementById('adjustProductName').textContent = btn.dataset.productName;
        document.getElementById('adjustCurrentQty').textContent  = btn.dataset.currentQty;
        document.getElementById('adjustUom').textContent         = btn.dataset.uom;

        // Reset form
        document.getElementById('typeAdd').checked = true;
        document.querySelector('[name="quantity"]').value = '';
        document.querySelector('[name="reason"]').value = '';
    });

    document.addEventListener('DOMContentLoaded', async function () {
        const savedDivId = @(Model.DivisionId?.ToString() ?? "null");
        const savedCatId = @(Model.CategoryId?.ToString() ?? "null");
        const savedSubId = @(Model.SubCategoryId?.ToString() ?? "null");

        // select-enhance.js wraps every non-modal .form-select on DOMContentLoaded before this
        // listener runs (registered after it), so .tomselect is guaranteed to exist here.
        const divSel = document.getElementById('filterDivision').tomselect;
        const catSel = document.getElementById('filterCategory').tomselect;
        const subSel = document.getElementById('filterSubCategory').tomselect;

        function reloadInventory(overrides) {
            window.SadaleneLiveSearch.reload('#inventory-table-region', overrides);
        }

        async function loadCategories(divId, selectValue) {
            catSel.clear(true);
            catSel.clearOptions();
            catSel.addOption({ value: '', text: 'All Categories' });
            catSel.refreshOptions(false);

            subSel.clear(true);
            subSel.clearOptions();
            subSel.addOption({ value: '', text: 'All Sub-Categories' });
            subSel.refreshOptions(false);

            if (!divId) return;

            const data = await fetch(`/api/master/categories?divisionId=${divId}`).then(r => r.json());
            catSel.clearOptions();
            catSel.addOption({ value: '', text: 'All Categories' });
            data.forEach(c => catSel.addOption({ value: String(c.id), text: c.name }));
            catSel.refreshOptions(false);
            if (selectValue) catSel.setValue(String(selectValue), true);
        }

        async function loadSubCategories(catId, selectValue) {
            subSel.clear(true);
            subSel.clearOptions();
            subSel.addOption({ value: '', text: 'All Sub-Categories' });
            subSel.refreshOptions(false);

            if (!catId) return;

            const data = await fetch(`/api/master/subcategories?categoryId=${catId}`).then(r => r.json());
            subSel.clearOptions();
            subSel.addOption({ value: '', text: 'All Sub-Categories' });
            data.forEach(s => subSel.addOption({ value: String(s.id), text: s.name }));
            subSel.refreshOptions(false);
            if (selectValue) subSel.setValue(String(selectValue), true);
        }

        // Initialise cascades with any filter already present in the URL (e.g. a bookmarked link) —
        // setValue's silent flag (true) avoids firing 'change' and triggering a redundant reload,
        // since the server already rendered the table filtered to these values.
        await loadCategories(savedDivId, savedCatId);
        await loadSubCategories(savedCatId, savedSubId);

        divSel.on('change', function (divId) {
            loadCategories(divId, null);
            reloadInventory({ divisionId: divId, categoryId: '', subCategoryId: '' });
        });

        catSel.on('change', function (catId) {
            loadSubCategories(catId, null);
            reloadInventory({ divisionId: divSel.getValue(), categoryId: catId, subCategoryId: '' });
        });

        subSel.on('change', function (subId) {
            reloadInventory({ divisionId: divSel.getValue(), categoryId: catSel.getValue(), subCategoryId: subId });
        });
    });
</script>
}
