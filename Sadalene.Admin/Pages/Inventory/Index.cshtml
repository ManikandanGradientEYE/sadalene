@page
@using Microsoft.AspNetCore.Mvc.Rendering
@model Sadalene.Admin.Pages.Inventory.IndexModel
@{
    ViewData["Title"] = "Inventory";
    ViewData["ActiveMenu"] = "Inventory";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-boxes me-2"></i>Inventory</h5>
    <a asp-page="Update" asp-route-divisionId="@Model.DivisionId" asp-route-categoryId="@Model.CategoryId"
       asp-route-subCategoryId="@Model.SubCategoryId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-upload me-1"></i>Update Inventory
    </a>
</div>
