@model Sadalene.Admin.Pages.Inventory.AdjustmentHistoryModel

<div class="card">
    <div class="card-header fw-semibold py-2">
        <i class="bi bi-clock-history me-2"></i>Adjustment History
        <span class="badge bg-secondary ms-2">@Model.Logs.TotalCount entries</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0 small">
            <thead class="table-light">
                <tr><th>Date / Time</th><th>Product</th><th>Division</th><th>Type</th><th class="text-end">Qty</th><th class="text-end">Before</th><th class="text-end">After</th><th>Reason</th><th>By</th></tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs.Items)
                {
                    var (icon, cls) = log.AdjustmentType switch {
                        "Add"      => ("bi-plus-circle-fill", "text-success"),
                        "Subtract" => ("bi-dash-circle-fill", "text-danger"),
                        _          => ("bi-pencil-fill",      "text-primary")
                    };
                    <tr>
                        <td class="text-muted">@log.AdjustedAt.ToString("dd MMM yy HH:mm")</td>
                        <td class="fw-semibold">@log.Product.Name</td>
                        <td><span class="badge bg-secondary bg-opacity-75">@log.Product.Division.Name</span></td>
                        <td><span class="@cls"><i class="bi @icon me-1"></i>@log.AdjustmentType</span></td>
                        <td class="text-end">@log.Quantity.ToString("N2")</td>
                        <td class="text-end text-muted">@log.PreviousQuantity.ToString("N2")</td>
                        <td class="text-end fw-semibold">@log.NewQuantity.ToString("N2")</td>
                        <td class="text-muted">@log.Reason</td>
                        <td class="text-muted">@log.AdjustedBy</td>
                    </tr>
                }
                @if (Model.Logs.Items.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No adjustments found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.Logs" />
</div>
