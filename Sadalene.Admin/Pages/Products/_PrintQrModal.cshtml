<!-- Print QR Code Modal. Trigger with data-bs-toggle="modal" data-bs-target="#printQrModal" data-sku="...". -->
<div class="modal fade" id="printQrModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-qr-code me-2"></i>Print QR Code</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <div id="printQrPreview" class="mb-2 d-flex justify-content-center"></div>
                <div class="text-muted small font-monospace mb-3" id="printQrSku"></div>
                <div class="text-start">
                    <label class="form-label fw-semibold">Quantity</label>
                    <input type="number" id="printQrQty" class="form-control" value="1" min="1" max="500" />
                    <div class="form-text">Each label prints this QR code, sized 1cm × 1cm.</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmPrintQrBtn" class="btn btn-primary btn-sm">
                    <i class="bi bi-printer me-1"></i>Print
                </button>
            </div>
        </div>
    </div>
</div>
