@page "{id:int}"
@model Sadalene.Admin.Pages.Products.BarcodeModel
@{
    ViewData["Title"] = "Barcode";
    ViewData["ActiveMenu"] = "Products";
    var sku = Model.Product!.ProductCode ?? $"SD{Model.Product.Id:D5}";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Barcode — @Model.Product.Name</h5>
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card text-center">
            <div class="card-header fw-semibold">Barcode Preview</div>
            <div class="card-body py-4">
                <svg id="barcodePreview"></svg>
                <div class="mt-2 text-muted small">The barcode encodes this product's SKU.</div>
                <div class="mt-3">
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#printModal">
                        <i class="bi bi-printer me-1"></i>Print Barcode
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-header fw-semibold">Product Info</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Division</dt>     <dd class="col-7">@Model.Product.Division.Name</dd>
                    <dt class="col-5 text-muted">Category</dt>     <dd class="col-7">@Model.Product.Category.Name</dd>
                    <dt class="col-5 text-muted">Sub-Category</dt> <dd class="col-7">@Model.Product.SubCategory.Name</dd>
                    <dt class="col-5 text-muted">Product Code (SKU)</dt> <dd class="col-7 font-monospace">@sku</dd>
                    <dt class="col-5 text-muted">Brand</dt>        <dd class="col-7">@(Model.Product.Brand ?? "—")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<!-- Print Quantity Modal -->
<div class="modal fade" id="printModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-printer me-2"></i>Print Barcode Labels</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label fw-semibold">Quantity</label>
                <input type="number" id="printQty" class="form-control" value="1" min="1" max="500" />
                <div class="form-text">Each label prints the SKU as a barcode, sized 1cm × 1cm.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmPrintBtn" class="btn btn-primary btn-sm">
                    <i class="bi bi-printer me-1"></i>Print
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
<script>
    const sku = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sku));

    JsBarcode('#barcodePreview', sku, {
        format: 'CODE128',
        displayValue: true,
        fontSize: 14,
        height: 50,
        margin: 6
    });

    function buildLabelSvgMarkup() {
        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        JsBarcode(svg, sku, {
            format: 'CODE128',
            displayValue: true,
            fontSize: 6,
            height: 18,
            margin: 0
        });
        return svg.outerHTML;
    }

    document.getElementById('confirmPrintBtn').addEventListener('click', function () {
        const qty = Math.max(1, Math.min(500, parseInt(document.getElementById('printQty').value, 10) || 1));
        const labelSvg = buildLabelSvgMarkup();
        const labelsHtml = Array.from({ length: qty }, () => `<div class="label">${labelSvg}</div>`).join('');

        const win = window.open('', '_blank', 'width=400,height=400');
        if (!win) { alert('Please allow pop-ups to print barcode labels.'); return; }

        win.document.write(`<!DOCTYPE html>
<html><head><title>Print Barcode — ${sku}</title>
<style>
    @@page { size: 1cm 1cm; margin: 0; }
    * { box-sizing: border-box; }
    body { margin: 0; }
    .label {
        width: 1cm; height: 1cm;
        display: flex; align-items: center; justify-content: center;
        page-break-after: always;
        overflow: hidden;
    }
    .label svg { width: 100%; height: 100%; }
</style>
</head><body>${labelsHtml}</body></html>`);
        win.document.close();

        win.onload = function () {
            setTimeout(function () { win.print(); }, 150);
        };
        win.onafterprint = function () { win.close(); };
    });
</script>
}
