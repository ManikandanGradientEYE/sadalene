@page "{id:int}"
@model Sadalene.Admin.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
    ViewData["ActiveMenu"] = "Products";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Edit Product</h5>
</div>

<form method="post">
    <input type="hidden" asp-for="Input.Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

    <!-- Classification -->
    <div class="card mb-3">
        <div class="card-header fw-semibold py-2 bg-light"><i class="bi bi-diagram-3 me-2"></i>Classification</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Division <span class="text-danger">*</span></label>
                    <select asp-for="Input.DivisionId" id="divisionSelect" class="form-select" asp-items="Model.Divisions">
                        <option value="">— Select Division —</option>
                    </select>
                    <span asp-validation-for="Input.DivisionId" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                    <select asp-for="Input.CategoryId" id="categorySelect" class="form-select">
                        <option value="@Model.Input.CategoryId">Loading...</option>
                    </select>
                    <span asp-validation-for="Input.CategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Sub-Category <span class="text-danger">*</span></label>
                    <select asp-for="Input.SubCategoryId" id="subCategorySelect" class="form-select">
                        <option value="@Model.Input.SubCategoryId">Loading...</option>
                    </select>
                    <span asp-validation-for="Input.SubCategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Product Type <span class="text-danger">*</span></label>
                    <select asp-for="Input.ProductTypeId" class="form-select" asp-items="Model.ProductTypes">
                        <option value="">— Select Type —</option>
                    </select>
                    <span asp-validation-for="Input.ProductTypeId" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Identity -->
    <div class="card mb-3">
        <div class="card-header fw-semibold py-2 bg-light"><i class="bi bi-tag me-2"></i>Product Identity</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">SKU / Product Code</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-upc"></i></span>
                        <input asp-for="Input.ProductCode" class="form-control" />
                    </div>
                    <div class="form-text">Unique. Leave unchanged to keep the existing SKU.</div>
                    <span asp-validation-for="Input.ProductCode" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Product Name (Mill) <span class="text-danger">*</span></label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Market Name</label>
                    <input asp-for="Input.MarketName" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Design No.</label>
                    <input asp-for="Input.DesignNo" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Grade</label>
                    <input asp-for="Input.Grade" class="form-control" />
                </div>
                <div class="col-md-7">
                    <label class="form-label fw-semibold">Description</label>
                    <input asp-for="Input.Description" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- Pricing & UOM -->
    <div class="card mb-3">
        <div class="card-header fw-semibold py-2 bg-light"><i class="bi bi-currency-rupee me-2"></i>Pricing & Unit of Measure</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Unit of Measure (UOM)</label>
                    <select asp-for="Input.UomMasterId" id="uomSelect" class="form-select" asp-items="Model.UomList">
                        <option value="0">— None —</option>
                    </select>
                    <div class="form-text">Inherited from Sub-Category. You can override.</div>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Rate</label>
                    <input asp-for="Input.Rate" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Rate Per</label>
                    <input asp-for="Input.RatePer" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Cut</label>
                    <input asp-for="Input.Cut" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Qty Per Unit</label>
                    <input asp-for="Input.QtyPerUnit" class="form-control" type="number" step="0.001" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Packing Type</label>
                    <select asp-for="Input.PackingTypeId" class="form-select" asp-items="Model.PackingTypes">
                        <option value="0">— Select —</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Fabric Specs -->
    <div class="card mb-3">
        <div class="card-header fw-semibold py-2 bg-light"><i class="bi bi-patch-check me-2"></i>Fabric Specifications</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Fabric Composition</label>
                    <input asp-for="Input.FabricComposition" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Width</label>
                    <input asp-for="Input.Width" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Weight</label>
                    <input asp-for="Input.Weight" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">Color</label>
                    <input asp-for="Input.Color" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Design</label>
                    <input asp-for="Input.Design" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Brand</label>
                    <input asp-for="Input.Brand" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- Other -->
    <div class="card mb-3">
        <div class="card-header fw-semibold py-2 bg-light"><i class="bi bi-sliders me-2"></i>Other</div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Display Order</label>
                    <input asp-for="Input.DisplayOrder" type="number" class="form-control" />
                </div>
                <div class="col-md-3 pb-1">
                    <div class="form-check">
                        <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="Input.IsActive" class="form-check-label fw-semibold">Active</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-2"></i>Save Changes</button>
        <a asp-page="Barcode" asp-route-id="@Model.Input.Id" class="btn btn-outline-warning">
            <i class="bi bi-upc-scan me-2"></i>Manage Barcode
        </a>
        <a asp-page="Index" class="btn btn-secondary ms-auto">Cancel</a>
    </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    const savedDivId  = @Model.Input.DivisionId;
    const savedCatId  = @Model.Input.CategoryId;
    const savedSubId  = @Model.Input.SubCategoryId;

    const divSel  = document.getElementById('divisionSelect');
    const catSel  = document.getElementById('categorySelect');
    const subSel  = document.getElementById('subCategorySelect');
    const uomSel  = document.getElementById('uomSelect');

    async function loadCategories(divId, selectValue) {
        catSel.innerHTML = '<option value="">Loading...</option>';
        subSel.innerHTML = '<option value="">— Select Category first —</option>';
        if (!divId) { catSel.innerHTML = '<option value="">— Select Division first —</option>'; return; }
        const data = await fetch(`/api/master/categories?divisionId=${divId}`).then(r => r.json());
        catSel.innerHTML = '<option value="">— Select Category —</option>';
        data.forEach(c => catSel.add(new Option(c.name, c.id)));
        if (selectValue) catSel.value = selectValue;
    }

    async function loadSubCategories(catId, selectValue) {
        subSel.innerHTML = '<option value="">Loading...</option>';
        if (!catId) { subSel.innerHTML = '<option value="">— Select Category first —</option>'; return; }
        const data = await fetch(`/api/master/subcategories?categoryId=${catId}`).then(r => r.json());
        subSel.innerHTML = '<option value="">— Select Sub-Category —</option>';
        data.forEach(s => {
            const opt = new Option(s.name, s.id);
            opt.dataset.uomMasterId = s.uomMasterId ?? '';
            subSel.add(opt);
        });
        if (selectValue) subSel.value = selectValue;
    }

    // Initialise cascades on page load with saved values (don't override saved UOM)
    (async () => {
        await loadCategories(savedDivId, savedCatId);
        await loadSubCategories(savedCatId, savedSubId);
    })();

    divSel.addEventListener('change', async () => await loadCategories(divSel.value, null));
    catSel.addEventListener('change', async () => await loadSubCategories(catSel.value, null));

    subSel.addEventListener('change', () => {
        const selected = subSel.options[subSel.selectedIndex];
        const uomId = selected?.dataset?.uomMasterId ?? '';
        if (uomId && (!uomSel.value || uomSel.value === '0')) uomSel.value = uomId;
    });
</script>
}
