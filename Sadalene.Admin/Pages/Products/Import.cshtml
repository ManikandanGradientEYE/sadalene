@page
@model Sadalene.Admin.Pages.Products.ImportModel
@{
    ViewData["Title"] = "Import Products";
    ViewData["ActiveMenu"] = "Products";
}

<div class="d-flex align-items-center mb-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0 fw-bold">Import Products from Excel</h5>
</div>

<div class="card mb-4" style="max-width:700px">
    <div class="card-body">
        <p class="text-muted small mb-3">
            Download the template, fill in your products, then upload it below. Columns marked with
            <span class="text-danger fw-semibold">*</span> are required. Division, Category, Sub Category,
            Product Type, Packing Type and UOM are matched by name — if a name doesn't already exist it will
            be created automatically, so you don't need to set those up first.
        </p>
        <p class="text-muted small mb-3">
            <i class="bi bi-info-circle me-1"></i><strong>DivisionCode</strong> is optional and only applies when a new Division is
            being created by the import (existing Divisions keep their current code). It's used as the prefix for
            auto-generated SKUs, e.g. <code>PNN00034</code>.
        </p>
        <a asp-page-handler="Template" class="btn btn-outline-secondary btn-sm mb-4">
            <i class="bi bi-download me-1"></i>Download Excel Template
        </a>

        <form method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label fw-semibold">Excel File</label>
                <input type="file" name="file" class="form-control" accept=".xlsx" required />
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-2"></i>Import</button>
        </form>
    </div>
</div>

@if (Model.ImportedCount > 0 || Model.Errors.Count > 0)
{
    <div class="card" style="max-width:700px">
        <div class="card-body">
            <h6 class="fw-bold mb-3">Import Result</h6>
            @if (Model.ImportedCount > 0)
            {
                <p class="text-success mb-2"><i class="bi bi-check-circle me-1"></i>@Model.ImportedCount product(s) imported successfully.</p>
            }
            @if (Model.Errors.Count > 0)
            {
                <p class="text-danger fw-semibold mb-2">@Model.Errors.Count row(s) skipped:</p>
                <ul class="text-danger small mb-0">
                    @foreach (var e in Model.Errors)
                    {
                        <li>@e</li>
                    }
                </ul>
            }
        </div>
    </div>
}
