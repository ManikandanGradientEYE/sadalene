@page
@model Sadalene.Admin.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
    ViewData["ActiveMenu"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-grid me-2"></i>Products</h5>
    <div>
        <a asp-page="Import" class="btn btn-outline-secondary btn-sm me-2"><i class="bi bi-upload me-1"></i>Import</a>
        <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add Product</a>
    </div>
</div>

<div class="mb-3" data-live-search data-target="#products-table-region">
    <input data-search-input type="text" class="form-control" style="max-width:320px"
           placeholder="Search by name, code or category..." value="@Model.Search" />
</div>
<div id="products-table-region">
    <partial name="_ProductsTable" model="Model" />
</div>
